# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Credential Encryption (REQUIRED)
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=your-32-character-minimum-encryption-key

# Resend Configuration
RESEND_USER_AGENT=ZeRelayBackend/1.0
RESEND_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_secret

# Optional: Server-wide fallback API key (local dev only)
RESEND_API_KEY=re_your_api_key

